//@version=5
indicator("0 DTE SPX Pro: Compact View", overlay=true, max_labels_count=500)

// --- 1. Inputs ---
maLength      = input.int(20, "Trend MA")
atrLength     = input.int(14, "ATR Volatility Period")
labelOffset   = input.float(1.2, "Label Distance", minval=0.5, step=0.1)

// --- 2. Core Indicators ---
ma      = ta.sma(close, maLength)
rsiVal  = ta.rsi(close, 14)
[macdLine, signalLine, _] = ta.macd(close, 12, 26, 9)

// Volatility Check
atr = ta.atr(atrLength)
atrSma = ta.sma(atr, 20)
volExpansion = atr > atrSma 

// --- 3. Momentum Logic ---
stochRaw = ta.stoch(close, high, low, 14)
k = ta.sma(stochRaw, 3) 
d = ta.sma(k, 3)        

bullMomentum = k > d and k > 40
bearMomentum = k < d and k < 60

// --- 4. Session Median ---
var float sessionMid = na
if ta.change(time("D"))
    sessionMid := hl2
else
    sessionMid := (ta.highest(high, 50) + ta.lowest(low, 50)) / 2

// --- 5. Logic ---
bullish = close > ma and rsiVal > 50 and macdLine > signalLine and volExpansion and close > sessionMid and bullMomentum
bearish = close < ma and rsiVal < 50 and macdLine < signalLine and volExpansion and close < sessionMid and bearMomentum

// --- 6. Visuals ---
bgcolor(bullish ? color.new(color.green, 93) : bearish ? color.new(color.red, 93) : na)
plot(ma, color=color.new(color.blue, 60), title="Trend MA")

// --- 7. SMALL COMPACT LABELS ---
yDist = atr * labelOffset

if bullish
    label.new(bar_index, low - yDist, 
         text="C:@" + str.tostring(close, "#.##"), 
         color=color.green, 
         textcolor=color.white, 
         style=label.style_label_up, 
         size=size.small) // Small block size

if bearish
    label.new(bar_index, high + yDist, 
         text="P:@" + str.tostring(close, "#.##"), 
         color=color.red, 
         textcolor=color.white, 
         style=label.style_label_down, 
         size=size.small) // Small block size

// --- 8. Small Dashboard ---
var table statusTable = table.new(position.top_right, 1, 1)
if barstate.islast
    table.cell(statusTable, 0, 0, bullish ? "BULL" : bearish ? "BEAR" : "WAIT", 
         bgcolor = bullish ? color.green : bearish ? color.red : color.gray, 
         text_color = color.white,
         text_size = size.small)//@version=5
